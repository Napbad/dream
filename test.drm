// 这是一个单行注释
/* 这是一个多行注释 */
// `;`作为每条语句的结尾

package com.napbad.main; // 这是一个包声明，指定当前文件属于 `main` 包

imt int i! = 1;

fun main(imt int arg) {
    var int a! = 10; // 这是一个变量声明
    var int b? = 20; // 这是一个变量声明，`b` 可以为 null

    b + i + arg; // 这是一个变量访问
    a = b;

    a;
}

main(4);

fun start_thread() {
    native;
}

start_thread();