class Test{
    public const fun test() {
        /println("Hello!");
        /println(("Dream Version: 0.0.1"));
    }
}

fun test_main() {
    imt Test test! = new Test();
    test.test();
}

fun test_main1(imt int a!) int{
    /println("Hello!");
    return a + 1;
}

