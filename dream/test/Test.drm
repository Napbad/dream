package test;

import natives.net.Socket;

// 字符串类型 (string)
// 可变且可空
var string str1?;
str1 = "Hello, world!";

// 可变且不可空
var string str2!;
str2 = "Hello, world!";

// 不可变且可空
imt string str3? = "Hello, world!"; // 不可变变量只能在声明时赋值一次

// 不可变且不可空
imt string str4! = "Hello, world!"; // 不可变变量只能在声明时赋值一次

// 整数类型 (int)
