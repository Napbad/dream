fun main() int {
    /println(c);
    /println(d);
    /println(a);
    /println(b);
    /println(b1);

    if b1 == b || a == 10 {
        /println("b1 == b or a == 10!");
    }

    if b1 != "he" {
        /println("b1 != \"he\"");
    } else {
        /println("b1 == \"he\"");
    }

    if a1 > 10 {
        /println("a1 > 10");
    } else if a1 < 10 {
        /println("a1 < 10");
    } else {
        /println("a1 == 10");
    }

    for int i = 0; i < 10; i = i + 1 {
        var string j = "i = ";
        /println(j);
        /println(i);
    }

    try {
        /println("try");
        throw new Exception("error");
    } catch Exception e {
        /println("failed");
    } finally {
        /println("finally");
    }

    imt int a! = test(1, 2);
    /println(a);

    Socket socket = new Socket();
}


