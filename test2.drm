// 这是一个单行注释
/* 这是一个多行注释 */
// `;`作为每条语句的结尾

package com.napbad.main; // 这是一个包声明，指定当前文件属于 `main` 包

import com.napbad.std; // 这是一个导入语句，导入 `com.napbad.std` 包
import com.napbad.http; // 这是一个导入语句，导入 `com.napbad.http` 包

var string b? =
// "a";
(((1 + 4) * 5) + 4 + 10 / 2 * 0.5) + "a";
// (20 + 10 * 40 - 100 / 5) + 10 * (10 + -1) % 4;
 // + (true & a | "ab");

b;

var string b1? = b;

b1;
b;

var int a! = 10; // 这是一个变量声明
// `var` 表示 `a` 是一个可变变量
// `!` 表示 `a` 不可以为 null，并且初始化为 10
// `?` 表示它可以为 null，例如 `a?`

// 支持的变量有这些类型：
// byte short int long flo  at double bool char string

var string c? = "Hello, world!";

c; // 这是一个变量访问，打印 `c` 的值

a; // 这是一个变量访问，可以打印 `a` 的值到标准输出

// 加上[]，表示数组
var int[] d? = [1, 2, 3];
var string[] e? = ["Hello", "world"];
imt int[] f! = [2,3,4];

d;

e;

a = 20; // 这是一个赋值语句，表示 `a` 的值现在变为 20

a; // 这是一个变量访问，再次获取 `a` 的值

imt int m! = 100; // 这是一个不可变变量声明
// `imt` 表示 `m` 是一个不可变变量

m; // 这是一个变量访问

m = 120; // 这是一个赋值语句，但由于 `m` 是不可变的，这将导致错误

m;

{
    m;
    var int tmp! = 10;
    tmp;
    {
        tmp = 20;
        tmp;
        m;
    }
}

@Main
// 这是一个函数注解，表示这个函数是程序的入口点
// 但实际上 `main` 函数是默认的入口点
@Fancy
fun main(string[] args) {
    // 这是一个函数声明
    // `fun` 表示这是一个函数
    // `main` 是函数名
    // `string[]` 表示 `args` 是一个字符串数组

    var int a! = 10; // 这是一个变量声明
    var int b? = 20; // 这是一个变量声明，`b` 可以为 null

    b; // 这是一个变量访问

    imt Test t! = new Test(); // 这是一个对象声明，`t` 是一个 `Test` 对象, `!` 表示 `t` 不可以为 null, imt 表示 `t` 是不可变的
    t.test(); // 这是一个对象访问，调用 `t` 的 `test()` 方法
    t.a;
    t.a + b; // 这是一个表达式，表示 `t.a` 加上 `b` 的值
    // 支持的运算有 + - * / % < > <= >= == != && || & | ^ ! ~ >> << >>>

}

annotation class Fancy {
    var int a! = 10; // 这是一个注解类的属性
    var int b? = 20; // 这是一个注解类的属性，可以为 null
}

@Fancy
class Test {

    public var int a! = 10; // 这是一个变量声明
    var int b? = 20; // 这是一个变量声明，可以为 null， `b` 是一个可变变量

    imt string s! = "Hello, world!"; // 这是一个不可变字符串
    private static imt string t! = "Hello, world! t"; // 这是一个不可变私有静态字符串
    protected imt string u! = "Hello, world! u"; // 这是一个不可变私有静态字符串

    fun test() {
        var @Fancy int a! = 10; // 这是一个变量声明，带有 `@Fancy` 注解
        a; // 这是一个变量访问
    }

    fun test2(int a!) int? {
        // 这是一个方法声明，`test2` 是一个方法，接收一个参数 `a`，返回一个 `int?` 类型的值
        // `int?` 表示 `a` 可以为 null，并且返回值为 `int?` 类型的值

        if a > 10 {
            return null;
        } else if a < 10 {
            return 10;
        } else {
            return a;
        }

        return a; // 这是一个返回语句，返回 `a` 的值
    }

    Test(){
        //
    } // 这是一个构造函数
}

class Test1 : Test { // 表示继承自 `Test`
    fun test1() int? {

        for int i = 0; i < 10; ++i {

            if i % 2 == 0 { // 条件不需要括号
                continue; // 跳过当前循环
            } else if (i % 3 == 0) && (i ==9) {
                break; // 跳出当前循环
            } else {
                continue;
            }

            println(i); // 一个方法，不需要解析println为关键字
        }

        for true {
            println("Hello, world!"); // 一个方法，不需要解析println为关键字
            break;
        }

        return null; // 返回空
    }
    // 这是一个方法
}

interface Test2 {}

class Test3 : Test1, Test2 { // 表示继承自 `Test1` 实现了 `Test2`
    fun test3() (int!, string?) { // 表示返回值为int 和 string, int不可为空，但是string可以为空
        imt string s! = "Hello, world!"; // 这是一个不可变字符串

        {
            println(10);
        }

        try {
            throw new Exception("wrong");
        } catch (Exception e) {
            println("err" + e.err());
        } finally {
            println("www");
        }

        A a = (a) b;
        A a = new A(a, b);
        throw new Exception("wrong");

        imt int a = (int)((~(((10 >>> 4) * (100 + 40 / 34 + m)) << 2 + 3) * 1000) | (10.19 * (10 * 100)));

//         try{}
//             println(10);
//         }
//         catch (Exception e) {
//             println(100 + "10");
//         } finally {
//             println("finally");
//         }

        return (10, s); // 返回值，与返回类型匹配
    }
    // 这是一个方法
}
